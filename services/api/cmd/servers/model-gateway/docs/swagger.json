        "/model-gateway/start": {
            "post": {
                "security": [
                    {
                        "Bearer": []
                    }
                ],
                "description": "Start a new WebRTC session with the speech service and return connection information",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "model-gateway"
                ],
                "summary": "Create WebRTC connection",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
