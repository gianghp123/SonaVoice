# Terraform state
*.tfstate
*.tfstate.*

# Terraform plan files
*.tfplan
*.plan

# Variable files
*.tfvars
*.tfvars.json

# Terraform working directory
.terraform/
**/.terraform/*

# Terraform lock file (optional)
# Usually KEEP this committed
# .terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json